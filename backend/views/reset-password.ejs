<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>GymBro - Reset Passowrd</title>
</head>
<body>
    <div class="h-screen bg-gradient-to-tl from-green-400 to-indigo-900 w-full py-16 px-4">
        <div class="flex flex-col items-center justify-center">

           <img src="https://tuk-cdn.s3.amazonaws.com/can-uploader/sign_in-svg1.svg" alt="logo">

            <form action="" method="post" class="bg-white shadow rounded lg:w-1/3  md:w-1/2 w-full p-10 mt-16">
                <p tabindex="0" class="focus:outline-none text-2xl font-extrabold leading-6 text-gray-800 mb-8">Reset Account Password</p>
                
                <div class="mt-6  w-full">
                    <label for="password" class="text-sm font-medium leading-none text-gray-800">
                        Password
                    </label>
                    <div class="relative flex items-center justify-center">
                    <input type="password" name="password" id="password" class="bg-gray-200 border rounded  text-xs font-medium leading-none text-gray-800 py-3 w-full pl-3 mt-2"/>
                    </div>
                </div>
                <div class="mt-6  w-full">
                    <label for="password2" class="text-sm font-medium leading-none text-gray-800">
                        Confirm Password
                    </label>
                    <div class="relative flex items-center justify-center">
                    <input  type="password" name="password2" id="password2" class="bg-gray-200 border rounded  text-xs font-medium leading-none text-gray-800 py-3 w-full pl-3 mt-2"/>
                    </div>
                </div>
                <div class="mt-8">
                    <button type="submit" class="focus:ring-2 focus:ring-offset-2 focus:ring-indigo-700 text-sm font-semibold leading-none text-white focus:outline-none bg-indigo-700 border rounded hover:bg-indigo-600 py-4 w-full">Create my account</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>